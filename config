{
    "position": "top",
    "height": 35,
    "spacing": 12,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
        "custom/arch",
        "hyprland/workspaces",
        "mpris"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "pulseaudio",
        "backlight",
        "custom/battery",
        "cpu",
        "memory",
        "network"
    ],
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "persistent-workspaces": {
            "*": 5
        },
        "anim-color-1": "#00e5ff",
        "anim-color-2": "#b347ff",
        "anim-duration": 3,
        "button-radius": 15,
        "button-pad-v": 0,
        "button-pad-h": 4,
        "button-minw": 35,
        "on-click": "activate"
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 60,
        "separate-outputs": true
    },
    "clock": {
        "format": "’ĆŚ  {:%d/%m/%Y %H:%M}",
        "timezone": "America/Monterrey",
        "locale": "es_MX.utf8",
        "interval": 1,
        "on-click": "flatpak run com.ml4w.calendar",
        "tooltip": true
    },
    "cpu": {
        "format": "¾░╗Ā {usage}%",
        "tooltip": true,
        "interval": 2
    },
    "memory": {
        "format": "Ņ┐ģ {used:0.1f}G/{total:0.1f}G",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "interval": 5
    },
    "network": {
        "format-wifi": "¾░¢® {essid}",
        "format-ethernet": "¾░łĆ Ethernet",
        "format-disconnected": "¾░¢¬ Hors ligne",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{essid} ({signalStrength}%)\nŌåæ {bandwidthUpBits}  Ōåō {bandwidthDownBits}",
        "on-click": "nm-connection-editor",
        "interval": 5,
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ipaddr}"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "Ņ╗© muted",
        "format-icons": {
            "default": [
                "’Ć”",
                "’Ć¦",
                "’Ć©"
            ]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": [
            "’ēä",
            "’ēā",
            "’ēé",
            "’ēü",
            "’ēĆ"
        ],
        "format-charging": "’ā¦ {capacity}%",
        "format-plugged": "’ć” {capacity}%",
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format-full": "’ēĆ {capacity}%",
        "tooltip-format": "{capacity}% - {timeTo}\n{power}W"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": [
            "ŌŚŗ",
            "ŌŚö",
            "ŌŚæ",
            "ŌŚĢ",
            "ŌŚÅ"
        ],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "ŌÅĖ {dynamic}",
        "dynamic-len": 40,
        "dynamic-order": [
            "title",
            "artist"
        ],
        "player-icons": {
            "spotify": "’å╝",
            "firefox": "’ē®",
            "chromium": "’ē©",
            "default": "’Ćü"
        },
        "status-icons": {
            "paused": "ŌÅĖ",
            "playing": "Ō¢Č"
        },
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl stop",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "tray": {
        "spacing": 8,
        "icon-size": 18
    },
    "custom/arch": {
        "format": "<span font='JetBrainsMono Nerd Font Mono 20' color='#c061cb'>¾░Żć</span>",
        "on-click": "$HOME/.local/bin/vsfetch",
        "tooltip": false,
        "arch-icon-glyph": "¾░Żć",
        "arch-pad-left": 15,
        "arch-pad-right": 10
    },
    "custom/weather": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/weather.py",
        "return-type": "json",
        "interval": 3600,
        "tooltip": true,
        "on-click": "flatpak run io.github.amit9838.mousam"
    },
    "custom/updates": {
        "exec": "count=$(checkupdates 2>/dev/null | wc -l); [ \"$count\" -gt 0 ] && echo '{\"text\":\"¾░Ü░ '\"$count\"'\",\"class\":\"pending\"}' || echo '{\"text\":\"¾░Ü░ 0\",\"class\":\"updated\"}'",
        "return-type": "json",
        "interval": 60,
        "tooltip": false,
        "on-click": "kitty --class floating-terminal -e ~/.config/hypr/scripts/install-updates.sh"
    },
    "custom/swaync": {
        "format": "<span font='JetBrainsMono Nerd Font Mono 16'>{icon}</span>",
        "format-icons": {
            "none": "¾░éÜ",
            "notification": "¾░é£",
            "dnd-none": "¾░éø",
            "dnd-notification": "¾░éø"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
        "tooltip": false
    },
    "custom/power": {
        "format": "ŌÅ╗",
        "on-click": "wlogout -b 3 -c 20 -r 20 -L 400 -R 400 -T 200 -B 200 --protocol layer-shell",
        "tooltip": false
    },
    "custom/settings": {
        "format": "¾░Æō",
        "on-click": "vswaybar-studio",
        "tooltip": false
    },
    "custom/battery": {
        "format": "¾░ś│",
        "tooltip": false
    }
}