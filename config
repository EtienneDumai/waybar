{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 6,

  "modules-left": [
    "hyprland/workspaces",
    "mpris"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "pulseaudio",
    "backlight",
    "custom/battery",
    "cpu",
    "memory",
    "network"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "persistent-workspaces": {
      "*": 5
    }
  },
  "backlight": {
  "device": "intel_backlight",
  "format": "{icon} {percent}%",
  "format-icons": ["○","◔","◑","◕","●"],
  "on-scroll-up": "brightnessctl set +5%",
  "on-scroll-down": "brightnessctl set 5%-"
},
  "mpris": {
    "format": "{player_icon} {dynamic}",
    "format-paused": "⏸ {dynamic}",
    "dynamic-len": 40,
    "dynamic-order": ["title", "artist"],
    "player-icons": {
      "spotify": "",
      "firefox": "",
      "chromium": "",
      "default": ""
    },
    "status-icons": {
      "paused": "⏸",
      "playing": "▶"
    },
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl stop",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },

  "clock": {
    "format": "  {:%d/%m/%Y %H:%M}"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": " muted",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol"
  },
  "custom/battery": {
  "exec": "~/.config/waybar/battery.sh",
  "interval": 10,
  "return-type": "json"
},
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-full": " {capacity}%",
    "format-icons": ["", "", "", "", ""],
    "tooltip-format": "{capacity}% - {timeTo}\n{power}W"
  },

  "cpu": {
    "format": "󰻠 {usage}%"
  },

  "memory": {
    "format": " {used:0.1f}G/{total:0.1f}G"
  },

  "network": {
    "format-wifi": "󰖩 {essid}",
    "format-ethernet": "󰈀 Ethernet",
    "format-disconnected": "󰖪 Hors ligne",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
    "tooltip-format-ethernet": "{ipaddr}"
  }
}
